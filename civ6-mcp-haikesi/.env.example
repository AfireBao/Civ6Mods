# Copy to .env and fill in your values (do not commit .env)

# --- DeepSeek（provider id: deepseek）---
DEEPSEEK_API_KEY=sk-your-deepseek-key
#   deepseek-v4-flash  — 快、便宜
#   deepseek-v4-pro    — 更强
DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- xAI Grok / 通用网关（provider id: grok|haikesi|xai）---
# HAIKESI_LLM_API_KEY=xai-your-key
# HAIKESI_LLM_BASE_URL=https://api.x.ai/v1
# HAIKESI_LLM_MODEL=grok-4.5

# --- 智谱 GLM（provider id: glm|zhipu|bigmodel）---
# GLM_API_KEY=your-zhipu-key
# GLM_MODEL=glm-5.2
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# --- 管线：single | dual ---
# HAIKESI_LLM_PIPELINE=single
# 初稿 / 审查 provider（任意组合，只改这两行即可切换）
# 内置：deepseek | grok | glm | openai | anthropic | draft | review
# HAIKESI_LLM_DRAFT=glm
# HAIKESI_LLM_REVIEW=deepseek
# 旧兼容：HAIKESI_LLM_DUAL_ORDER=grok_draft|deepseek_draft（未设 DRAFT/REVIEW 时）
# HAIKESI_LLM_REVIEW_ROUNDS=0


# --- OpenAI（provider id: openai）---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# --- Anthropic 原生（provider id: anthropic；不设 BASE_URL）---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- 角色专用端点（provider id: draft / review）---
# HAIKESI_DRAFT_API_KEY=...
# HAIKESI_DRAFT_BASE_URL=https://...
# HAIKESI_DRAFT_MODEL=...
# HAIKESI_REVIEW_API_KEY=...
# HAIKESI_REVIEW_BASE_URL=https://...
# HAIKESI_REVIEW_MODEL=...

# --- 自定义 provider（例：HAIKESI_LLM_DRAFT=foo）---
# HAIKESI_PROVIDER_FOO_API_KEY=...
# HAIKESI_PROVIDER_FOO_BASE_URL=https://...
# HAIKESI_PROVIDER_FOO_MODEL=...

HAIKESI_WATCH_INTERVAL_SEC=3
# HAIKESI_WATCH_MODE=auto
# HAIKESI_LUA_LOG=%LOCALAPPDATA%/Firaxis Games/Sid Meier's Civilization VI/Logs/Lua.log
# HAIKESI_LAST_PROMPT_PATH=G:/Civ6Mods/civ6-mcp-haikesi/logs/haikesi_last_prompt.txt

# --- 思考 / 自审 / 归档 ---
# HAIKESI_LLM_THINKING=1
# HAIKESI_LLM_REVIEW_ROUNDS=0
# HAIKESI_LLM_REASONING_EFFORT=high
# HAIKESI_LLM_MAX_TOKENS=4096
# HAIKESI_LLM_MAX_TOKENS_THINKING=12288
# 同一存档多轮对话（默认开；文件在 decisions/<save>/llm_chat_session.json）
# HAIKESI_LLM_CHAT_SESSION=1
# HAIKESI_LLM_CHAT_HISTORY_TURNS=6
# HAIKESI_LLM_CHAT_HISTORY_CHARS=120000
# HAIKESI_REASON_MODE=short
# HAIKESI_DECISION_LOG=0
# HAIKESI_DECISION_ARCHIVE_DIR=G:/Civ6Mods/civ6-mcp-haikesi/logs/decisions
# HAIKESI_LLM_JSON_MODE=0

# --- ToolLoop（薄 prompt + 按需索取；SP/MP 共用只读缓存）---
# HAIKESI_LLM_TOOLS=0
# HAIKESI_LLM_TOOL_ROUNDS=3
# 前 N 轮 tool_choice=auto；最后一轮 =none 强制出 JSON（Immersive 同款）
# 中后期可开审查（薄版 draft 用 tools，review 仍 plain）：
# HAIKESI_LLM_REVIEW_ROUNDS=1
# 词典：knowledge/civilopedia/index.json（export_civilopedia_index.py 再生）
# 可选：CIV6_GAME_ROOT=F:/SteamLibrary/steamapps/common/Sid Meier's Civilization VI
