# Copy to .env and fill in your values (do not commit .env)

# --- DeepSeek（推荐）---
DEEPSEEK_API_KEY=sk-your-deepseek-key
# 模型二选一（同一套 key / base_url，改这一行即可）:
#   deepseek-v4-flash  — 快、便宜（当前常用）
#   deepseek-v4-pro    — 更强，贵约 3×，决策更稳
DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# 两者上下文均为约 1M tokens；本任务 Prompt 通常仅数千～一万多字符，远未顶满

# --- xAI Grok（官方 OpenAI 兼容；用 haikesi_llm_watch.py / haikesi_llm_decide.py）---
# 在 https://console.x.ai 创建密钥（形如 xai-...）
# HAIKESI_LLM_API_KEY=xai-your-key
# HAIKESI_LLM_BASE_URL=https://api.x.ai/v1
# 模型以控制台 Models 为准，常见：grok-4.3（性价比）/ grok-4.5（更强）
# HAIKESI_LLM_MODEL=grok-4.3

# --- 其他 OpenAI 兼容网关（可选）---
# HAIKESI_LLM_API_KEY=sk-...
# HAIKESI_LLM_BASE_URL=https://api.example.com/v1
# HAIKESI_LLM_MODEL=your-model

# --- Anthropic 原生（不设 BASE_URL）---
# HAIKESI_LLM_API_KEY=sk-ant-...
# HAIKESI_LLM_MODEL=claude-sonnet-4-20250514

HAIKESI_WATCH_INTERVAL_SEC=3
# auto=有 FireTuner 用 Tuner，否则 Lua.log+热键（联机）；tuner|log 可强制
# HAIKESI_WATCH_MODE=auto
# HAIKESI_LUA_LOG=%LOCALAPPDATA%/Firaxis Games/Sid Meier's Civilization VI/Logs/Lua.log

# 每次提交后覆盖写入最近一次 Prompt（默认 logs/haikesi_last_prompt.txt）
# HAIKESI_LAST_PROMPT_PATH=G:/Civ6Mods/civ6-mcp-haikesi/logs/haikesi_last_prompt.txt

# --- 思考过程双模式（开发 vs 游玩）---
# 1=开发：自由 <thinking> 后 JSON；0=游玩：不写推演，省 token
# HAIKESI_LLM_THINKING=1
# 自审轮数 0–5：初稿后再让模型 Review N 次才提交（费用≈(1+N) 倍，开发用）
# HAIKESI_LLM_REVIEW_ROUNDS=2
# xAI：THINKING=1 时的 reasoning_effort（low|medium|high；grok-4.5 不支持 none）
# HAIKESI_LLM_REASONING_EFFORT=high
# 游玩 THINKING=0 时：grok-4.3→none，grok-4.5→自动 low
# HAIKESI_LLM_MAX_TOKENS=4096
# HAIKESI_LLM_MAX_TOKENS_THINKING=12288
# 理由：off=JSON不写(省token) | short/full=仅写入 decision 日志，不注入游戏
# HAIKESI_REASON_MODE=short
# 开发分析：写入 logs/decisions/<对局>/ 归档每场全部 decision；并镜像 logs/haikesi_last_decision.md
# HAIKESI_DECISION_LOG=0
# HAIKESI_DECISION_ARCHIVE_DIR=G:/Civ6Mods/civ6-mcp-haikesi/logs/decisions
# JSON Output 与 thinking 前言冲突；thinking=1 时会强制关
# HAIKESI_LLM_JSON_MODE=0
